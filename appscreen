    LaunchedEffect(naverMapInstance, apartmentKeys, favoriteBuildingKeys) {
        val map = naverMapInstance ?: return@LaunchedEffect

        when {
            apartmentKeys != MapHolder.lastApartmentKeys -> {
                MapHolder.lastApartmentKeys = apartmentKeys
                MapHolder.lastFavoriteBuildingKeys = favoriteBuildingKeys
                syncMapMarkers(context, map, apartments, favoriteBuildingKeys, onMarkerClick)
            }
            favoriteBuildingKeys != MapHolder.lastFavoriteBuildingKeys && MapHolder.markerMap.isNotEmpty() -> {
                MapHolder.lastFavoriteBuildingKeys = favoriteBuildingKeys
                refreshFavoriteMarkerStyles(context, map, favoriteBuildingKeys)
            }
        }
    }

    // 지도 View는 최초 1회만 부착. update 블록 비움 → 탭 전환 시 재렌더 없음
    AndroidView(
        factory = {
            if (mapView.parent != null) {
                (mapView.parent as? android.view.ViewGroup)?.removeView(mapView)
            }
            mapView
        },
        modifier = Modifier.fillMaxSize(),
        update = { }
    )
}

private fun syncMapMarkers(
    context: Context,
    map: NaverMap,
    apartments: List<ApartmentEntity>,
    favoriteBuildingKeys: Set<String>,
    onMarkerClick: (ApartmentEntity) -> Unit
) {
    val markerMap = MapHolder.markerMap
    val entityMap = MapHolder.markerEntities
    val activeKeys = mutableSetOf<String>()
    val isDark = map.isNightModeEnabled

    apartments.forEach { apt ->
        val lat = apt.latitude ?: return@forEach
        val lng = apt.longitude ?: return@forEach
        val key = apartmentMarkerKey(apt)
        activeKeys.add(key)
        val isFav = apartmentBuildingKey(apt) in favoriteBuildingKeys
        val icon = OverlayImage.fromBitmap(
            createMarkerBitmap(
                context = context,
                name = apt.name,
                price = apt.price.formattedPrice,
                isFavorite = isFav,
                isDark = isDark
            )
        )

        val existing = markerMap[key]
        if (existing != null) {
            existing.position = LatLng(lat, lng)
            existing.icon = icon
            if (existing.map == null) existing.map = map
        } else {
            val marker = Marker().apply {
                position = LatLng(lat, lng)
                this.icon = icon
                anchor = android.graphics.PointF(0.5f, 1.0f)
                setOnClickListener {
                    onMarkerClick(entityMap[key] ?: apt)
                    true
                }
            }
            marker.map = map
            markerMap[key] = marker
        }
        entityMap[key] = apt
    }

    (markerMap.keys - activeKeys).forEach { staleKey ->
        markerMap[staleKey]?.map = null
        markerMap.remove(staleKey)
        entityMap.remove(staleKey)
    }
}

private fun refreshFavoriteMarkerStyles(
    context: Context,
    map: NaverMap,
    favoriteBuildingKeys: Set<String>
) {
    val isDark = map.isNightModeEnabled
    MapHolder.markerMap.forEach { (key, marker) ->
        val apt = MapHolder.markerEntities[key] ?: return@forEach
        val isFav = apartmentBuildingKey(apt) in favoriteBuildingKeys
        marker.icon = OverlayImage.fromBitmap(
            createMarkerBitmap(
                context = context,
                name = apt.name,
                price = apt.price.formattedPrice,
                isFavorite = isFav,
                isDark = isDark
            )
        )
        if (marker.map == null) marker.map = map
    }
}

