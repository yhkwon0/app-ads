                    contentDescription = "Filter settings",
                    tint = PremiumBrown,
                    modifier = Modifier.size(16.dp)
                )
            }

            val priceActive = currentFilter.minPrice > 0 || currentFilter.maxPrice < Int.MAX_VALUE
            val priceText = if (priceActive) {
                fun formatPrice(value: Int): String {
                    if (value == 0) return "0"
                    val billion = value / 10000
                    val million = value % 10000
                    return if (billion > 0 && million > 0) {
                        "${billion}억 ${million / 1000},000"
                    } else if (billion > 0) {
                        "${billion}억"
                    } else {
                        "${million / 1000},000"
                    }
                }
                val pMin = formatPrice(currentFilter.minPrice)
                val pMax = if (currentFilter.maxPrice == Int.MAX_VALUE) " 이상" else " ~ ${formatPrice(currentFilter.maxPrice)}"
                "$pMin$pMax 금액 ▼"
            } else {
                "금액 전체"
            }

            Box(
                modifier = Modifier
                    .clip(RoundedCornerShape(50.dp))
                    .background(if (priceActive) Color.Transparent else PremiumCellBackground)
                    .border(1.dp, if (priceActive) PremiumBrown else PremiumCellBorder, RoundedCornerShape(50.dp))
                    .clickable { onFilterClick() }
                    .padding(horizontal = 8.dp, vertical = 5.dp)
            ) {
                Text(
                    text = priceText,
                    color = if (priceActive) PremiumBrown else Color(0xFF8E8E93),
                    fontSize = 13.sp,
                    fontWeight = FontWeight.Medium,
                    textAlign = TextAlign.Center
                )
            }

            val areaActive = currentFilter.minArea > 0 || currentFilter.maxArea < Int.MAX_VALUE
            val areaText = if (areaActive) {
                val aMin = currentFilter.minArea
                val aMax = if (currentFilter.maxArea == Int.MAX_VALUE) " 이상" else " ~ ${currentFilter.maxArea}평"
                "${aMin}평$aMax ▼"
            } else {
                "면적 전체"
            }

            Box(
                modifier = Modifier
                    .clip(RoundedCornerShape(50.dp))
                    .background(if (areaActive) Color.Transparent else PremiumCellBackground)
                    .border(1.dp, if (areaActive) PremiumBrown else PremiumCellBorder, RoundedCornerShape(50.dp))
                    .clickable { onFilterClick() }
                    .padding(horizontal = 8.dp, vertical = 5.dp)
            ) {
                Text(
                    text = areaText,
                    color = if (areaActive) PremiumBrown else Color(0xFF8E8E93),
                    fontSize = 13.sp,
                    fontWeight = FontWeight.Medium,
                    textAlign = TextAlign.Center
                )
            }
        }

        Box(
            modifier = Modifier
                .fillMaxWidth()
                .padding(top = 8.dp),
            contentAlignment = Alignment.Center
        ) {
            Row(
                modifier = Modifier
                    .width(220.dp),
                verticalAlignment = Alignment.CenterVertically
            ) {
                androidx.compose.foundation.text.BasicTextField(
                    value = query,
                    onValueChange = onQueryChange,
                    singleLine = true,
                    keyboardOptions = KeyboardOptions(imeAction = ImeAction.Search),
                    keyboardActions = KeyboardActions(onSearch = { onSearch() }),
                    // 1. 실제 입력되는 글자도 Baseline이 무너지지 않게 정렬
                    textStyle = LocalTextStyle.current.copy(
                        color = PremiumText,
                        fontSize = 12.sp,
                        textAlign = TextAlign.Start
                    ),
                    cursorBrush = androidx.compose.ui.graphics.SolidColor(PremiumMain),
                    decorationBox = { innerTextField ->
                        Row(
                            modifier = Modifier
                                .fillMaxWidth()
                                .height(38.dp)
                                .clip(RoundedCornerShape(19.dp))
                                .background(PremiumCellBackground)
                                .border(1.dp, PremiumCellBorder, RoundedCornerShape(19.dp))
                                .padding(horizontal = 12.dp),
                            verticalAlignment = Alignment.CenterVertically // Row 안의 모든 요소를 무조건 수직 중앙 정렬
                        ) {
                            Icon(
                                imageVector = Icons.Default.Search,
                                contentDescription = null,
                                tint = PremiumUnselected,
                                modifier = Modifier.size(18.dp)
                            )
                            Spacer(modifier = Modifier.width(8.dp))

                            // 2. 힌트 텍스트와 입력창이 완벽하게 겹치도록 수직 정렬 바구니 구성
                            Box(
                                modifier = Modifier.weight(1f),
                                contentAlignment = Alignment.CenterStart
                            ) {
                                if (query.isEmpty()) {
                                    Text(
                                        text = "지역명으로 검색 (예: 강남구)",
                                        color = PremiumUnselected,
                                        fontSize = 12.sp,
                                        textAlign = TextAlign.Start,
                                        modifier = Modifier.fillMaxWidth()
                                    )
                                }
                                Box(
                                    modifier = Modifier.fillMaxWidth(),
                                    contentAlignment = Alignment.CenterStart
                                ) {
                                    innerTextField()
                                }
                            }
                            if (query.isNotEmpty()) {
                                Icon(
                                    imageVector = Icons.Default.Clear,
                                    contentDescription = "Clear",
                                    tint = PremiumUnselected,
                                    modifier = Modifier
                                        .size(18.dp)
                                        .clickable { onQueryChange("") }
                                )
                            }
                        }
                    }
                )
            }

            Box(
                modifier = Modifier
                    .fillMaxWidth()
                    .padding(end = 16.dp),
                contentAlignment = Alignment.CenterEnd
            ) {
                FloatingActionButton(
                    onClick = onGpsClick,
                    shape = RoundedCornerShape(50),
                    containerColor = PremiumCellBackground,
                    contentColor = PremiumMain,
                    modifier = Modifier.size(36.dp),
                    elevation = FloatingActionButtonDefaults.elevation(2.dp)
                ) {
                    Icon(
                        imageVector = Icons.Default.LocationOn,
                        contentDescription = "GPS 현위치 이동",
                        modifier = Modifier.size(18.dp)
                    )
                }
            }
        }

        // 📍 이탈해있던 상하 패딩과 정중앙 정렬 속성을 iOS 스타일로 완벽 정렬 수정한 캡슐 버튼
        Box(
            modifier = Modifier
                .fillMaxWidth()
                .padding(vertical = 8.dp),
            contentAlignment = Alignment.Center
        ) {
            Surface(
                color = if (isSearchingNearby) PremiumBeige.copy(alpha = 0.8f) else PremiumBeige,
                shape = RoundedCornerShape(20.dp),
                border = androidx.compose.foundation.BorderStroke(1.dp, if (isSearchingNearby) PremiumMain.copy(alpha = 0.8f) else PremiumMain),
                shadowElevation = if (isSearchingNearby) 0.dp else 4.dp,
                modifier = Modifier
                    .clip(RoundedCornerShape(20.dp))
                    .clickable(enabled = !isSearchingNearby) { onCurrentLocationSearchClick() }
            ) {
                Row(
                    modifier = Modifier.padding(horizontal = 20.dp, vertical = 9.dp),
                    verticalAlignment = Alignment.CenterVertically,
                    horizontalArrangement = Arrangement.Center
                ) {
                    if (isSearchingNearby) {
                        CircularProgressIndicator(
                            modifier = Modifier
                                .padding(end = 6.dp)
                                .size(12.dp),
                            color = PremiumBrown,
                            strokeWidth = 2.dp
                        )
                    }
                    Text(
                        text = "📍 현위치 검색",
                        color = if (isSearchingNearby) PremiumBrown.copy(alpha = 0.6f) else PremiumBrown,
                        fontSize = 12.sp,
                        fontWeight = FontWeight.Bold,
                        textAlign = TextAlign.Center
                    )
                }
            }
        }
    }
}
