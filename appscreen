@Composable
fun MapScreen(
    modifier: Modifier = Modifier,
    viewModel: MapViewModel = viewModel(),
    onNavigateToDetail: (ApartmentEntity) -> Unit = {},
) {
    val activity = LocalContext.current as ComponentActivity
    val context = LocalContext.current
    val focusManager = LocalFocusManager.current
    val uiState by viewModel.uiState.collectAsState()

    var searchQuery by remember { mutableStateOf("") }
    var showFilterDialog by remember { mutableStateOf(false) }
    var selectedApartment by remember { mutableStateOf<ApartmentEntity?>(null) }

    var naverMapInstance by remember { mutableStateOf<NaverMap?>(null) }
    val locationSource = remember(activity) {
        activity?.let { FusedLocationSource(it, 1000) }
    }

    val permissions = arrayOf(
        android.Manifest.permission.ACCESS_FINE_LOCATION,
        android.Manifest.permission.ACCESS_COARSE_LOCATION
    )

    var locationPermissionGranted by remember {
        mutableStateOf(
            permissions.all {
                androidx.core.content.ContextCompat.checkSelfPermission(context, it) == android.content.pm.PackageManager.PERMISSION_GRANTED
            }
        )
    }

    val permissionLauncher = rememberLauncherForActivityResult(
        contract = ActivityResultContracts.RequestMultiplePermissions()
    ) { results ->
        locationPermissionGranted = results.values.all { it }
    }

    LaunchedEffect(Unit) {
        Log.d(DEBUG_TAG, "Location permission granted=$locationPermissionGranted")
        if (!locationPermissionGranted) {
            permissionLauncher.launch(permissions)
        }
    }

    // Toast messages
    LaunchedEffect(uiState.toastMessage) {
        uiState.toastMessage?.let {
            Toast.makeText(context, it, Toast.LENGTH_SHORT).show()
            viewModel.clearToast()
        }
    }

    val coroutineScope = rememberCoroutineScope()
    if (uiState.showAlertMessage == "reward_ad_needed") {
        androidx.compose.material3.AlertDialog(
            onDismissRequest = { viewModel.clearAlertMessage() },
            title = {
                androidx.compose.material3.Text(
                    text = "개발자에게 큰 힘이 됩니다!",
                    fontWeight = FontWeight.Bold,
                    fontSize = 18.sp
                )
            },
            text = {
                androidx.compose.material3.Text(
                    text = "관심아파트 추가는 1개까지만 무료입니다.\n광고를 시청하고\n관심아파트를 추가해보세요. ( 최대 10개 )",
                    fontSize = 14.sp
                )
            },
            confirmButton = {
                androidx.compose.material3.TextButton(
                    onClick = {
                        viewModel.clearAlertMessage()
                        coroutineScope.launch {
                            val success = com.yhkwon.apartment.utils.RewardedAdManager.showAd(context as ComponentActivity)
                            if (success) {
                                viewModel.forceToggleFavorite()
                            } else {
                                Toast.makeText(context, "광고 시청을 완료하지 못했습니다.", Toast.LENGTH_SHORT).show()
                            }
                        }
                    }
                ) {
                    androidx.compose.material3.Text("광고 시청", color = PremiumMain, fontWeight = FontWeight.Bold)
                }
            },
            dismissButton = {
                androidx.compose.material3.TextButton(
                    onClick = { viewModel.clearAlertMessage() }
                ) {
                    androidx.compose.material3.Text("취소", color = PremiumUnselected)
                }
            },
            containerColor = PremiumCellBackground,
            titleContentColor = PremiumText,
            textContentColor = PremiumText
        )
    } else if (uiState.showAlertMessage != null) {
        androidx.compose.material3.AlertDialog(
            onDismissRequest = { viewModel.clearAlertMessage() },
            title = { androidx.compose.material3.Text("알림") },
            text = { androidx.compose.material3.Text(uiState.showAlertMessage!!) },
            confirmButton = {
                androidx.compose.material3.TextButton(onClick = { viewModel.clearAlertMessage() }) {
                    androidx.compose.material3.Text("확인", color = PremiumMain)
                }
            },
            containerColor = PremiumCellBackground,
            titleContentColor = PremiumText,
            textContentColor = PremiumText
        )
    }

    BoxWithConstraints(modifier = modifier.fillMaxSize().background(PremiumBeige)) {
        val isTabletOrFoldable = maxWidth > 600.dp

        if (isTabletOrFoldable) {
            // 태블릿 레이아웃
            Row(modifier = Modifier.fillMaxSize()) {
                Box(modifier = Modifier.weight(1.5f).fillMaxHeight()) {
                    val showSkeleton = uiState.isLoading && uiState.filteredApartments.isEmpty() && !uiState.isInitialized
                    MapViewContainer(
                        uiState = uiState,
                        viewModel = viewModel,
                        locationPermissionGranted = locationPermissionGranted,
                        onMarkerClick = { apartment ->
                            onNavigateToDetail(apartment)
                        },
                        locationSource = locationSource,
                        onMapReady = { map ->
                            naverMapInstance = map
                        },
                        onMapClick = {
                            selectedApartment = null
                        }
                    )
                    if (showSkeleton) {
                        Box(
                            modifier = Modifier
                                .fillMaxSize()
                                .background(Color(0xFF2C2C2E))
                        ) {
                            Text(
                                text = "Loading map...",
                                color = Color.White.copy(alpha = 0.7f),
                                fontSize = 16.sp,
                                modifier = Modifier.align(Alignment.Center)
                            )
                        }
                    }
                    MapOverlayLayout(
                        query = searchQuery,
                        onQueryChange = { searchQuery = it },
                        onSearch = {
                            viewModel.search(searchQuery)
                            focusManager.clearFocus()
                        },
                        onFilterClick = { showFilterDialog = true },
                        onGpsClick = {
                            val loc = locationSource?.lastLocation
                            if (loc != null) {
                                naverMapInstance?.moveCamera(
                                    CameraUpdate.scrollTo(LatLng(loc.latitude, loc.longitude))
                                        .animate(CameraAnimation.Easing)
                                )
                            }
                        },
                        onCurrentLocationSearchClick = {
                            // iOS: mapView.projection.latlng(from: mapView.center) 과 동일하게
                            // MapHolder에 항상 살아있는 NaverMap 인스턴스에서 현재 카메라 중심 좌표를 가져옴
                            val map = MapHolder.getNaverMap()
                            map?.cameraPosition?.target?.let { target ->
                                viewModel.searchNearby(target.latitude, target.longitude)
                            }
                        },
                        currentFilter = uiState.currentFilter,
                        isSearchingNearby = uiState.isSearchingNearby
                    )
                }

                Box(
                    modifier = Modifier
                        .weight(1f)
                        .fillMaxHeight()
                        .background(PremiumCellBackground)
                        .border(1.dp, PremiumCellBorder)
                        .padding(16.dp)
                ) {
                    Column {
                        Text(
                            text = "상세 정보",
                            color = PremiumText,
                            style = MaterialTheme.typography.titleMedium,
                            fontWeight = FontWeight.Bold,
                            modifier = Modifier.padding(bottom = 12.dp)
                        )
                        selectedApartment?.let { apt ->
                            ApartmentDetailCard(
                                apartment = apt,
                                isFav = uiState.favoriteIds.contains(apt.id),
                                modifier = Modifier.clickable { onNavigateToDetail(apt) }
                            )
                        } ?: Text("지도의 마커를 탭하여 아파트 세부 정보를 조회하세요.", color = PremiumUnselected)

                        Spacer(modifier = Modifier.weight(1f))

                        AdBannerPlaceholder()
                    }
                }
            }
        } else {
            // 스마트폰 세로 모드 레이아웃
            Box(modifier = Modifier.fillMaxSize()) {
                val showSkeleton = uiState.isLoading && uiState.filteredApartments.isEmpty() && !uiState.isInitialized
                MapViewContainer(
                    uiState = uiState,
                    viewModel = viewModel,
                    locationPermissionGranted = locationPermissionGranted,
                    onMarkerClick = { apartment ->
                        onNavigateToDetail(apartment)
                    },
                    locationSource = locationSource,
                    onMapReady = { map ->
                        naverMapInstance = map
                    },
                    onMapClick = {
                        selectedApartment = null
                    }
                )
                if (showSkeleton) {
                    Box(
                        modifier = Modifier
                            .fillMaxSize()
                            .background(Color(0xFF2C2C2E))
                    ) {
                        Text(
                            text = "Loading map...",
                            color = Color.White.copy(alpha = 0.7f),
                            fontSize = 16.sp,
                            modifier = Modifier.align(Alignment.Center)
                        )
                    }
                }

                // 2. 상단 필터바 및 플로팅 검색 레이어
                Box(modifier = Modifier.fillMaxWidth().align(Alignment.TopCenter)) {
                    MapOverlayLayout(
                        query = searchQuery,
                        onQueryChange = { searchQuery = it },
                        onSearch = {
                            viewModel.search(searchQuery)
                            focusManager.clearFocus()
                        },
                        onFilterClick = { showFilterDialog = true },
                        onGpsClick = {
                            val loc = locationSource?.lastLocation
                            if (loc != null) {
                                naverMapInstance?.moveCamera(
                                    CameraUpdate.scrollTo(LatLng(loc.latitude, loc.longitude))
                                        .animate(CameraAnimation.Easing)
                                )
                            }
                        },
                        onCurrentLocationSearchClick = {
                            // iOS: mapView.projection.latlng(from: mapView.center) 과 동일하게
                            // MapHolder에 항상 살아있는 NaverMap 인스턴스에서 현재 카메라 중심 좌표를 가져옴
                            val map = MapHolder.getNaverMap()
                            map?.cameraPosition?.target?.let { target ->
                                viewModel.searchNearby(target.latitude, target.longitude)
                            }
                        },
                        currentFilter = uiState.currentFilter,
                        isSearchingNearby = uiState.isSearchingNearby
                    )
                }

                // 3. 하단 광고 캡슐 레이어 (탭바 위에 가려짐 없이 표출되도록 높이 조율)
                Column(
                    modifier = Modifier
                        .fillMaxWidth()
                        .align(Alignment.BottomCenter)
                        .padding(bottom = 80.dp)
                ) {
                    Box(
                        modifier = Modifier
                            .fillMaxWidth()
                            .padding(horizontal = 0.dp, vertical = 0.dp)
                    ) {
                        AdBannerPlaceholder()
                    }
                }
            }
        }

        if (showFilterDialog) {
            FilterDialog(
                currentFilter = uiState.currentFilter,
                onDismiss = { showFilterDialog = false },
                onApply = { minP, maxP, minA, maxA ->
                    viewModel.updateFilter(minP, maxP, minA, maxA)
                    showFilterDialog = false
                }
            )
        }

        if (uiState.isLoading || uiState.isSearchingNearby) {
            Box(
                modifier = Modifier
                    .fillMaxSize()
                    .pointerInput(Unit) {
                        awaitPointerEventScope {
                            while (true) {
                                val event = awaitPointerEvent()
                                event.changes.forEach { it.consume() }
                            }
                        }
                    },
                contentAlignment = Alignment.Center
            ) {
                if (uiState.isLoading) {
                    CircularProgressIndicator(
                        color = PremiumBrown,
                        strokeWidth = 3.dp,
                        modifier = Modifier.size(36.dp)
                    )
                }
            }
        }
    } // BoxWithConstraints
} // MapScreen


@Composable
fun MapViewContainer(
    uiState: com.yhkwon.apartment.viewmodel.MapUiState,
    viewModel: MapViewModel,
    locationPermissionGranted: Boolean,
    onMarkerClick: (ApartmentEntity) -> Unit,
    locationSource: FusedLocationSource?,
    onMapReady: (NaverMap) -> Unit,
    onMapClick: () -> Unit = {}
) {
    val context = LocalContext.current
    val mapView = remember { MapHolder.getMapView(context) }
    var naverMapInstance by remember { mutableStateOf(MapHolder.getNaverMap()) }

    val lifecycleOwner = LocalLifecycleOwner.current
    val apartments = uiState.filteredApartments
    val favoriteBuildingKeys = uiState.favoriteBuildingKeys
    val apartmentKeys = apartments.map { apartmentMarkerKey(it) }.toSet()

    LaunchedEffect(naverMapInstance) {
        if (naverMapInstance != null) {
            viewModel.initialize()
        }
    }

    DisposableEffect(lifecycleOwner, mapView) {
        if (lifecycleOwner.lifecycle.currentState.isAtLeast(Lifecycle.State.STARTED)) {
            mapView.onStart()
        }
        if (lifecycleOwner.lifecycle.currentState.isAtLeast(Lifecycle.State.RESUMED)) {
            mapView.onResume()
        }

        val observer = LifecycleEventObserver { _, event ->
            when (event) {
                Lifecycle.Event.ON_START -> mapView.onStart()
                Lifecycle.Event.ON_RESUME -> mapView.onResume()
                Lifecycle.Event.ON_PAUSE -> mapView.onPause()
                Lifecycle.Event.ON_STOP -> mapView.onStop()
                Lifecycle.Event.ON_DESTROY -> mapView.onDestroy()
                else -> {}
            }
        }
        lifecycleOwner.lifecycle.addObserver(observer)
        onDispose { lifecycleOwner.lifecycle.removeObserver(observer) }
    }

    DisposableEffect(mapView) {
        if (MapHolder.getNaverMap() == null) {
            mapView.getMapAsync { map ->
                MapHolder.setNaverMap(map)
                naverMapInstance = map
                onMapReady(map)
                map.uiSettings.isZoomControlEnabled = false
                map.uiSettings.isLocationButtonEnabled = false
                map.isNightModeEnabled = true

                viewModel.uiState.value.lastCameraCenter?.let { lastCenter ->
                    map.moveCamera(CameraUpdate.scrollTo(LatLng(lastCenter.first, lastCenter.second)))
                }

                map.addOnCameraIdleListener {
                    val target = map.cameraPosition.target
                    viewModel.setLastCameraCenter(target.latitude, target.longitude)
                }

                map.setOnMapClickListener { _, coord ->
                    Log.d(DEBUG_TAG, "Map clicked at $coord")
                    onMapClick()
                }

                val currentApartments = viewModel.uiState.value.filteredApartments
                val currentFavKeys = viewModel.uiState.value.favoriteBuildingKeys
                if (currentApartments.isNotEmpty()) {
                    syncMapMarkers(context, map, currentApartments, currentFavKeys, onMarkerClick)
                }
            }
        }
        onDispose { }
    }

    // 카메라 이동 — 상태 변경 시에만
    LaunchedEffect(uiState.cameraMoveTarget, naverMapInstance, uiState.isSearchingNearby) {
        val target = uiState.cameraMoveTarget
        val map = naverMapInstance ?: return@LaunchedEffect
        if (target != null && !uiState.isSearchingNearby) {
            map.moveCamera(CameraUpdate.scrollTo(LatLng(target.first, target.second)))
            viewModel.clearCameraMoveTarget()
        }
    }

    // 지도 제스처 / GPS 초기화 — 최초 1회
    LaunchedEffect(
        naverMapInstance,
        uiState.isInitialized,
        uiState.hasMovedToInitialPosition,
        uiState.isLoading,
        locationPermissionGranted,
        uiState.currentFavorites.size
    ) {
        val map = naverMapInstance ?: return@LaunchedEffect
        map.isNightModeEnabled = true

        if (uiState.isSearchingNearby) {
            map.locationTrackingMode = LocationTrackingMode.None
            map.uiSettings.isScrollGesturesEnabled = false
            map.uiSettings.isZoomGesturesEnabled = false
            map.uiSettings.isTiltGesturesEnabled = false
            map.uiSettings.isRotateGesturesEnabled = false
        } else {
            map.uiSettings.isScrollGesturesEnabled = true
            map.uiSettings.isZoomGesturesEnabled = true
            map.uiSettings.isTiltGesturesEnabled = true
            map.uiSettings.isRotateGesturesEnabled = true
        }

        if (!uiState.hasMovedToInitialPosition && uiState.isInitialized && !uiState.isLoading) {
            if (!locationPermissionGranted) {
                viewModel.setHasMovedToInitialPosition(true)
            } else if (uiState.currentFavorites.isEmpty()) {
                map.locationSource = locationSource
                map.locationTrackingMode = LocationTrackingMode.Follow
                val loc = locationSource?.lastLocation
                if (loc != null) {
                    map.moveCamera(CameraUpdate.scrollTo(LatLng(loc.latitude, loc.longitude)))
                    viewModel.searchNearby(loc.latitude, loc.longitude)
                    viewModel.setHasMovedToInitialPosition(true)
                } else {
                    locationSource?.activate { location ->
                        if (location != null && !viewModel.uiState.value.hasMovedToInitialPosition) {
                            map.moveCamera(CameraUpdate.scrollTo(LatLng(location.latitude, location.longitude)))
                            viewModel.searchNearby(location.latitude, location.longitude)
                            viewModel.setHasMovedToInitialPosition(true)
                        }
                    }
                }
            }
        }

        @Composable
