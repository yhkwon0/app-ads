                            if (value == 0f) return "0원"
                            val billion = value.toInt()
                            val million = ((value - billion) * 10f).roundToInt()
                            return if (billion > 0 && million > 0) {
                                "${billion}억 ${million},000만"
                            } else if (billion > 0) {
                                "${billion}억"
                            } else {
                                "${million},000만"
                            }
                        }

                        val priceText = if (pMax >= 20f) {
                            "${formatPrice(pMin)} ~ 20억+"
                        } else {
                            "${formatPrice(pMin)} ~ ${formatPrice(pMax)}"
                        }

